# ── Routing ─────────────────────────────────────────────────────────
# Optional. If set, requests without X-Provider/X-Broker header use this.
# Leave empty to require explicit X-Provider on every request.
DEFAULT_PROVIDER=

# ── Providers directories ───────────────────────────────────────────
# Built-in YAML provider definitions (vendored with the image).
# In Docker the Dockerfile sets this to /app/app/builtin_providers automatically.
PROVIDERS_DIR=./app/builtin_providers
# Optional: extra directory the operator can mount with custom providers.
EXTRA_PROVIDERS_DIR=

# ── Network ─────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
TRUSTED_PROXIES=

# ── Infra ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
HOSTS_CONFIG_PATH=./hosts.yaml
RATE_LIMIT_QUEUE_TIMEOUT=2.0

# ── Provider credentials (only the ones you've enabled) ─────────────
# Groww — three flows are documented in app/builtin_providers/groww.yaml.
# Set the variables matching whichever auth block you uncommented there.
#   Flow #2 (default — API key + secret):   GROWW_API_KEY + GROWW_API_SECRET
#   Flow #3 (TOTP authenticator):           GROWW_API_KEY + GROWW_TOTP_SEED
#   Flow #1 (manual daily access token):    GROWW_ACCESS_TOKEN
GROWW_API_KEY=
GROWW_API_SECRET=
GROWW_TOTP_SEED=
GROWW_ACCESS_TOKEN=

# Upstox — operator-supplied OAuth token (rotate daily ~3:30 AM IST).
# Either set this here and restart, or run: redis-cli SET upstox:token <value>
UPSTOX_ACCESS_TOKEN=

# Example providers (disabled by default; set enabled: true in their YAML to use)
STRIPE_SECRET_KEY=
OPENAI_API_KEY=
