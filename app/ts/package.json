{
  "name": "outpost-ts",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Outpost — the edge sidecar for AI agents (TypeScript runtime, runs on Cloudflare Workers + Node.js)",
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx src/adapter/node.ts",
    "build": "tsup",
    "deploy:workers": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.1",
    "ipaddr.js": "^2.2.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.78.0"
  }
}
